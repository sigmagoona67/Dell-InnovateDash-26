# CareBridge AI — environment variables
# The live demo runs the polished frontend on InsForge. A standalone cloud-native
# microservices backend also ships in this repo (see backend/); set its section
# only if you run that instead.

# ─── Frontend (live demo · InsForge) ───
VITE_INSFORGE_URL=https://your-appkey.ap-southeast.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key_here

# Server-side only (InsForge edge functions / local scripts — never expose as VITE_*)
OPENROUTER_API_KEY=your_openrouter_key_from_insforge_ai_setup

# ─── Microservices backend (optional · see backend/) ───
# VITE_API_URL=http://localhost:3001   # only when the frontend targets the gateway instead of InsForge
APP_PORT=8080
APP_API_PORT=3001
DATABASE_URL=postgresql://carebridge:carebridge@localhost:5432/carebridge
JWT_SECRET=carebridge-dev-jwt-secret-change-in-production
SERVICE_API_KEY=carebridge-service-key
REDIS_URL=redis://localhost:6379
OPENROUTER_CHAT_MODEL=openai/gpt-4o
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=30000
