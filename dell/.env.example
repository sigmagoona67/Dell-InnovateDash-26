# CareBridge AI — microservices (cloud-native backend)

# Frontend API gateway
VITE_API_URL=http://localhost:3001

# Docker Compose
APP_PORT=8080
APP_API_PORT=3001

# Backend / Postgres
DATABASE_URL=postgresql://carebridge:carebridge@localhost:5432/carebridge
JWT_SECRET=carebridge-dev-jwt-secret-change-in-production
SERVICE_API_KEY=carebridge-service-key

# Event bus (Redis Streams) — optional for local dev without Docker
REDIS_URL=redis://localhost:6379

# AI (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_CHAT_MODEL=openai/gpt-4o

# K8s service discovery (set per-service in cluster, e.g. AUTH_SERVICE_HOST=carebridge-auth)
# SERVICE_DEFAULT_HOST=127.0.0.1

# Resilience
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=30000
