# Copy to secret.yaml, fill values, then: kubectl apply -f k8s/secret.yaml
# secret.yaml is gitignored — never commit real keys.
apiVersion: v1
kind: Secret
metadata:
  name: carebridge-backend-secrets
  namespace: carebridge
  labels:
    app.kubernetes.io/name: carebridge
type: Opaque
stringData:
  JWT_SECRET: "change-me-in-production"
  SERVICE_API_KEY: "carebridge-service-key"
  OPENROUTER_API_KEY: ""
  DATABASE_URL: "postgresql://carebridge:carebridge@carebridge-postgres:5432/carebridge"
